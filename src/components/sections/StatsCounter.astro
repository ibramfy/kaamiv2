---
// StatsCounter.astro
// Animasi: counter angka sekali saat enter via ScrollTrigger once
import StatItem from "../ui/StatItem.astro";

const stats = [
    { target: 15, label: "Years Exp.", suffix: "" },
    { target: 120, label: "Projects", suffix: "+" },
    { target: 24, label: "Awards", suffix: "" },
    { target: 100, label: "Commitment", suffix: "%" },
];
---

<section
    id="stats-section"
    class="mx-auto max-w-6xl py-32 border-t border-gray-200 border-b mt-20"
>
    <div class="grid grid-cols-2 gap-12 md:grid-cols-4">
        {
            stats.map((stat) => (
                <StatItem
                    target={stat.target}
                    label={stat.label}
                    suffix={stat.suffix}
                />
            ))
        }
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function init() {
        const section = document.getElementById("stats-section");
        if (!section) return;

        const ctx = gsap.context(() => {
            const counters = section.querySelectorAll<HTMLElement>(".counter");

            counters.forEach((counter) => {
                const target = parseFloat(
                    counter.getAttribute("data-target") || "0",
                );
                const triggerEl =
                    counter.parentElement?.parentElement ?? section;

                ScrollTrigger.create({
                    trigger: triggerEl,
                    start: "top 80%",
                    once: true,
                    onEnter: () => {
                        let obj = { val: 0 };
                        gsap.to(obj, {
                            val: target,
                            duration: 2,
                            ease: "power3.out",
                            onUpdate: () => {
                                counter.textContent = Math.floor(
                                    obj.val,
                                ).toString();
                            },
                        });
                    },
                });
            });
        }, section);

        return ctx;
    }

    let ctx: any;
    window.addEventListener("preloaderComplete", () => {
        ctx = init();
    });

    document.addEventListener("astro:before-swap", () => {
        if (ctx) ctx.revert();
    });
</script>
