---
// AboutReveal.astro
// Animasi: Scroll-linked reveal, muncul saat section masuk, hilang saat keluar
---

<section
    id="about-reveal-section"
    class="flex min-h-screen flex-col items-center justify-center px-4"
>
    <p
        id="about-reveal"
        class="text-center text-3xl font-light leading-tight tracking-tight text-[#1d1d1f] md:text-5xl lg:text-7xl opacity-0"
    >
        Dedikasi <span class="text-[#3A3A3A]">Nyata</span><br />
        Untuk Hunian Nyaman
    </p>

    <span
        id="about-subtitle"
        class="mt-6 text-sm md:text-base font-light tracking-wide text-[#86868b] underline underline-offset-4 decoration-1 opacity-0 cursor-default"
    >
        Experience what we mean.
    </span>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import SplitType from "split-type";

    gsap.registerPlugin(ScrollTrigger);

    function init() {
        const section = document.getElementById("about-reveal-section");
        if (!section) return;

        const ctx = gsap.context(() => {
            const textEl = section.querySelector<HTMLElement>("#about-reveal");
            const subtitleEl =
                section.querySelector<HTMLElement>("#about-subtitle");
            if (!textEl) return;

            const split = new SplitType(textEl, { types: "lines,words" });

            // Kumpulkan semua SVG di dalam paragraph (jika ada)
            const svgEls = Array.from(textEl.querySelectorAll<SVGElement>("svg"));

            // Semua animatable elements = kata + SVG + subtitle
            const allEls = [
                ...(split.words ?? []),
                ...svgEls,
                ...(subtitleEl ? [subtitleEl] : []),
            ];

            // Hapus opacity-0 dari container setelah split, atur initial state per elemen
            gsap.set(textEl, { opacity: 1 });
            gsap.set(allEls, { opacity: 0, y: 50 });

            // Satu timeline pinned dengan 3 phase: Fade IN → Hold → Fade OUT
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: section,
                    start: "top top",
                    end: "+=150%", // 50% extra untuk fade-out sebelum unpin
                    pin: true,
                    scrub: true,
                },
            });

            // Phase 1 — Fade IN: semua elemen masuk
            tl.to(allEls, {
                opacity: 1,
                y: 0,
                duration: 1,
                stagger: 0.05,
                ease: "power2.out",
            });

            // Jeda singkat — elemen fully visible
            tl.to({}, { duration: 0.5 });

            // Phase 2 — Fade OUT: elemen pergi ke atas sebelum section unpin
            tl.to(allEls, {
                opacity: 0,
                y: -40,
                duration: 0.8,
                stagger: 0.03,
                ease: "power2.in",
            });
        }, section);

        return ctx;
    }

    let ctx: any;
    window.addEventListener("preloaderComplete", () => {
        ctx = init();
    });

    document.addEventListener("astro:before-swap", () => {
        if (ctx) ctx.revert();
    });
</script>
