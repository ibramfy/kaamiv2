---
// CtaInteractive.astro
// Animasi: scroll reveal + mouse tracking blob via gsap.context()
---

<section
    id="cta-section"
    class="relative mt-20 flex min-h-[60vh] flex-col items-center justify-center overflow-hidden rounded-[40px] bg-[#1d1d1f] text-white pt-20"
>
    <!-- Animated Background Elements -->
    <div
        class="absolute inset-0 z-0 opacity-20 pointer-events-none overflow-hidden"
    >
        <div
            id="cta-blob"
            class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-tr from-gray-400 to-transparent blur-[100px] will-change-transform"
        >
        </div>
    </div>

    <div class="z-10 text-center flex flex-col items-center pb-20">
        <h2 class="text-5xl font-light tracking-tight md:text-8xl">
            Start a Project
        </h2>
        <a
            href="/studio/contact"
            class="group relative mt-12 inline-flex items-center gap-4 overflow-hidden rounded-full border border-white/30 px-8 py-4 text-sm uppercase tracking-widest transition-colors hover:bg-white hover:text-black hover:border-white"
        >
            <span
                class="relative z-10 transition-transform duration-300 group-hover:-translate-y-10 group-hover:opacity-0 block"
            >
                Get in Touch
            </span>
            <span
                class="absolute inset-0 z-20 flex items-center justify-center translate-y-10 opacity-0 transition-transform duration-300 group-hover:translate-y-0 group-hover:opacity-100"
            >
                Get in Touch
            </span>
        </a>
    </div>

    <!-- Footer Links Overlay -->
    <div
        class="w-full border-t border-white/20 mt-auto px-6 py-6 md:px-20 z-10 flex flex-col md:flex-row justify-between items-center text-sm font-light text-gray-400"
    >
        <div>
            &copy; {new Date().getFullYear()} KAAMI Studio. All rights reserved.
        </div>
        <div class="flex gap-6 mt-4 md:mt-0 uppercase tracking-widest">
            <a href="#" class="hover:text-white transition-colors">Instagram</a>
            <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function init() {
        const section = document.getElementById("cta-section");
        if (!section) return;

        const ctx = gsap.context(() => {
            const blob = section.querySelector("#cta-blob");
            const h2 = section.querySelector("h2");

            if (h2) {
                gsap.from(h2, {
                    scrollTrigger: {
                        trigger: section,
                        start: "top 70%",
                    },
                    y: 50,
                    opacity: 0,
                    duration: 1,
                    ease: "power3.out",
                });
            }

            if (blob) {
                const moveBlob = (e: MouseEvent) => {
                    const rect = section.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;

                    gsap.to(blob, {
                        x: x * 0.5,
                        y: y * 0.5,
                        duration: 2,
                        ease: "power2.out",
                    });
                };

                const resetBlob = () => {
                    gsap.to(blob, {
                        x: 0,
                        y: 0,
                        duration: 2,
                        ease: "power2.out",
                    });
                };

                section.addEventListener("mousemove", moveBlob);
                section.addEventListener("mouseleave", resetBlob);
            }
        }, section);

        return ctx;
    }

    let ctx: any;
    window.addEventListener("preloaderComplete", () => {
        ctx = init();
    });

    document.addEventListener("astro:before-swap", () => {
        if (ctx) ctx.revert();
    });
</script>
