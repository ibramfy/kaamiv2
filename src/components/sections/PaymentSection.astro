<section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 items-stretch">
        <!-- Left: Content (Text) -->
        <div class="flex flex-col justify-between">
            <div>
                <!-- Title -->
                <h2
                    class="mt-3 text-3xl md:text-4xl font-light text-neutral-900"
                >
                    Bayar di Akhir Setelah Desain Selesai
                </h2>
                <p
                    class="mt-2 text-sm uppercase tracking-widest text-green-600 font-medium"
                >
                    Kami Berani – Anda Aman 100%
                </p>

                <!-- Description -->
                <p class="mt-6 text-lg leading-relaxed text-neutral-700">
                    Kaami menghapus sistem DP yang sering bikin was-was. Anda
                    hanya membayar pelunasan setelah melihat hasil desain
                    arsitektur 100% selesai, approve, dan benar-benar puas. Uang
                    Anda terlindungi sepenuhnya oleh sistem escrow resmi.
                </p>
            </div>

            <!-- Three Points -->
            <div class="mt-14 space-y-8">
                <div>
                    <h4 class="text-lg font-medium text-neutral-900">
                        Kerja Dulu, Bayar Kemudian
                    </h4>
                    <p class="mt-2 text-neutral-600 leading-relaxed">
                        Kami kerjakan full desain dari briefing, denah, 3D
                        realistis, gambar kerja, hingga RAB tanpa pembayaran
                        awal besar. Anda pantau progres setiap minggu melalui
                        dashboard pribadi dan update video via WA.
                    </p>
                </div>

                <div>
                    <h4 class="text-lg font-medium text-neutral-900">
                        Escrow Protection
                    </h4>
                    <p class="mt-2 text-neutral-600 leading-relaxed">
                        Pelunasan ditahan di Midtrans atau Xendit (berlisensi BI
                        & OJK). Uang baru cair setelah Anda approve hasil akhir.
                        Jika tidak puas, refund 100% dalam 24 jam — tanpa drama.
                    </p>
                </div>

                <div>
                    <h4 class="text-lg font-medium text-neutral-900">
                        Garansi Tanpa Syarat
                    </h4>
                    <p class="mt-2 text-neutral-600 leading-relaxed">
                        Revisi gratis sampai puas + garansi “Hasil tidak sesuai
                        brief = uang kembali penuh plus denda 15%”. Sudah
                        dipercaya 150+ klien di Jawa Timur tanpa satu keluhan
                        pun.
                    </p>
                </div>
            </div>

            <!-- CTA -->
            <div class="mt-10">
                <a
                    href="https://wa.me/628xxxxxxxxxx?text=Halo%20Kaami,%20saya%20mau%20desain%20dengan%20sistem%20bayar%20di%20akhir"
                    class="inline-flex items-center gap-3 bg-neutral-900 hover:bg-black text-white px-8 py-4 rounded-2xl text-lg font-medium transition-all"
                >
                    Mulai Proyek Sekarang – Bayar di Akhir
                    <span class="text-xl">→</span>
                </a>
            </div>
        </div>

        <!-- Right: Image Placeholder -->
        <div class="h-full w-full order-first md:order-last">
            <div
                class="h-full w-full rounded-2xl bg-gray-200 overflow-hidden flex items-center justify-center relative"
            >
                <!-- Ganti src ini dengan foto proyek Kaami lo nanti -->
                <img
                    src="https://via.placeholder.com/800x600/1f2937/ffffff?text=Proyek+Kaami"
                    alt="Proyek Arsitektur Kaami"
                    class="w-full h-full object-cover"
                />
                <div
                    class="absolute bottom-6 left-6 bg-white/90 backdrop-blur-sm px-5 py-2 rounded-xl text-sm font-medium text-neutral-900 shadow"
                >
                    Bayar setelah hasil jadi
                </div>
            </div>
        </div>
    </div>
</section>
