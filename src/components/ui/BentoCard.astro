---
interface Props {
    image?: string;
    alt?: string;
    title?: string;
    subtitle?: string;
    colSpan?: string;
    rowSpan?: string;
    variant?: "image" | "dark-cta";
    ctaHref?: string;
    ctaLabel?: string;
}

const {
    image,
    alt,
    title,
    subtitle,
    colSpan = "",
    rowSpan = "",
    variant = "image",
    ctaHref = "#",
    ctaLabel = "View Projects",
} = Astro.props;
---

{
    variant === "image" ? (
        <div
            class={`bento-item group relative overflow-hidden rounded-3xl bg-gray-200 ${colSpan} ${rowSpan}`}
        >
            <img
                src={image}
                alt={alt}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/20 opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
            {title && (
                <div class="absolute bottom-8 left-8 text-white opacity-0 transition-all duration-500 group-hover:translate-y-0 translate-y-4 group-hover:opacity-100">
                    <h3 class="text-2xl font-light">{title}</h3>
                    {subtitle && (
                        <p class="text-sm font-light tracking-widest text-gray-300">
                            {subtitle}
                        </p>
                    )}
                </div>
            )}
        </div>
    ) : (
        <div
            class={`bento-item group flex items-center justify-center overflow-hidden rounded-3xl bg-[#1d1d1f] p-8 text-white ${colSpan} ${rowSpan}`}
        >
            <div class="text-center">
                <h3 class="text-xl font-light">Explore Our Work</h3>
                <a
                    href={ctaHref}
                    class="mt-4 inline-block rounded-full border border-white/30 px-6 py-2 text-sm transition-colors hover:bg-white hover:text-black"
                >
                    {ctaLabel}
                </a>
            </div>
        </div>
    )
}
