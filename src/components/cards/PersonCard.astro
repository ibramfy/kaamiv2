---
interface Props {
    person: {
        name: string;
        role: string;
        bio: string;
    };
}

const { person } = Astro.props;
---

<!-- Inline Component -->
<div class="flex flex-col">
    <!-- Image Placeholder -->
    <div class="aspect-[3/4] w-full bg-neutral-200 rounded-2xl"></div>

    <!-- Text -->
    <div class="mt-6 space-y-3">
        <h3 class="text-xl font-medium text-[#1d1d1f]">
            {person.name}
        </h3>

        <p class="text-xs uppercase tracking-widest text-neutral-400">
            {person.role}
        </p>

        <p class="text-sm leading-relaxed text-neutral-600 line-clamp-2">
            {person.bio}
        </p>
    </div>
</div>
