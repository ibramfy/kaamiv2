---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Careers">
    <div
        class="flex min-h-screen items-center justify-center bg-[#F5F5F7] px-6 py-32 text-center md:px-20"
    >
        <div>
            <h1
                class="text-6xl font-light uppercase tracking-tighter text-[#1d1d1f] md:text-8xl lg:text-9xl"
            >
                Careers
            </h1>
            <p
                class="mt-8 text-xl font-light tracking-widest text-gray-500 uppercase"
            >
                Join the KAAMI team
            </p>
            <p class="mt-12 text-lg font-light text-[#1d1d1f]">
                Currently no open positions. Check back later.
            </p>
            <a
                href="/"
                class="mt-12 inline-block border-b border-[#1d1d1f] pb-1 text-sm uppercase tracking-widest transition-opacity hover:opacity-50"
                >Back to Home</a
            >
        </div>
    </div>
</BaseLayout>
